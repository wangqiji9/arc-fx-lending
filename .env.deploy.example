# ──────────────────────────────────────────────
# Arc Testnet Deployment Environment
# Copy to .env.deploy and fill in your values.
# NEVER commit .env.deploy to git.
# ──────────────────────────────────────────────

# === Step 1: Generate accounts ===
# Run: cast wallet new  (repeat 4 times for deployer/alice/bob/charlie)
# Fund each via Arc faucet: https://faucet.testnet.arc.network

PRIVATE_KEY=0x_DEPLOYER_PRIVATE_KEY

# === Step 2: Fill after DeployArc.s.sol output ===

LENDING_POOL_ADDRESS=0x
MOCK_EURC_ADDRESS=0x
MOCK_WETH_ADDRESS=0x
MOCK_ORACLE_ADDRESS=0x

# === Step 3: Simulation accounts (for SeedArc.s.sol) ===

PK_ALICE=0x_ALICE_PRIVATE_KEY
PK_BOB=0x_BOB_PRIVATE_KEY
PK_CHARLIE=0x_CHARLIE_PRIVATE_KEY
